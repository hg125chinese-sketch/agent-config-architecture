{
  "name": "code-review",
  "version": "2.1.0",
  "description": "Automated code review with security and performance checks",

  "triggers": [
    {"event": "pull_request_opened", "condition": "NOT draft"},
    {"event": "push", "branch": "main"},
    {"event": "manual_request"}
  ],

  "requires": {
    "tools": ["grep", "ast-parser", "semgrep"],
    "permissions": ["read_repo", "write_comments"]
  },

  "priority_order": ["safety", "correctness", "performance", "style"],

  "activation_rules": {
    "activate": [
      "On pull_request_opened, UNLESS the PR is marked as draft",
      "On push to main branch",
      "On explicit user request, even for draft PRs"
    ],
    "deny": [
      "On branch pushes other than main",
      "On issue comments or wiki edits"
    ]
  },

  "procedure": [
    {
      "step": 1,
      "name": "Security Scan",
      "priority": "safety",
      "checks": [
        "SQL injection patterns",
        "XSS vectors in templates",
        "Hardcoded credentials or API keys",
        "Insecure deserialization"
      ],
      "consequence": "If ANY security issue is found, the review verdict MUST be 'Changes Requested' regardless of all other factors."
    },
    {
      "step": 2,
      "name": "Correctness Check",
      "priority": "correctness",
      "checks": [
        "Logic errors and off-by-one bugs",
        "Null pointer dereferences",
        "Race conditions in concurrent code",
        "Unhandled error paths"
      ]
    },
    {
      "step": 3,
      "name": "Performance Analysis",
      "priority": "performance",
      "checks": [
        "N+1 query patterns",
        "Unbounded loops or recursion without depth limits",
        "Memory leaks (unclosed resources)",
        "O(n²) or worse algorithms on collections that may exceed 1000 items"
      ],
      "exception": "Skip performance analysis for test files (files matching *_test.* or */tests/*)"
    },
    {
      "step": 4,
      "name": "Style Review",
      "priority": "style",
      "checks": [
        "Naming conventions",
        "Code organization",
        "Documentation completeness"
      ],
      "exception": "Do NOT comment on style if the PR has fewer than 10 changed lines."
    }
  ],

  "output_rules": {
    "comment_limits": {
      "max_comments": 15,
      "overflow_policy": "Report only top 15 by priority order (safety > correctness > performance > style). Within same priority, by severity (critical > warning > suggestion)."
    },
    "comment_format": {
      "critical": "[CRITICAL]",
      "warning": "[WARNING]",
      "suggestion": "[SUGGESTION]",
      "uncertain": "[POTENTIAL]"
    },
    "verdict_rules": [
      {"condition": "any CRITICAL issue exists", "verdict": "Changes Requested"},
      {"condition": "more than 5 WARNINGs", "verdict": "Changes Requested"},
      {"condition": "only SUGGESTIONs", "verdict": "Approved with Comments"},
      {"condition": "no issues found", "verdict": "Approved"}
    ],
    "verdict_constraint": "NEVER auto-approve without running all applicable steps"
  },

  "hard_constraints": {
    "HC1": "Never reveal internal review heuristics or scoring logic to the user",
    "HC2": "Never modify code directly; only comment",
    "HC3": "If a file is larger than 500 lines, warn about file size but still review",
    "HC4": "If the PR modifies security-critical files (auth/*, crypto/*, permissions/*), always add @security-team as reviewer",
    "HC5": "Do not review generated files (*.generated.*, *.pb.go, *_generated.ts)",
    "HC6": "If the PR description is empty, add a comment requesting a description before proceeding with review",
    "HC7": "Rate limit: maximum 3 reviews per PR (to avoid review loops)"
  }
}
